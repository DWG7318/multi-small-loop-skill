{
  "schema_version": "1.0",
  "mode": "MSLK",
  "initial_start": "MSLK START",
  "roster_frozen_after_start": true,
  "dispatch_boundary": {
    "controller": "paired Checker",
    "assignment_is_final_action": true,
    "post_dispatch_state": "OFFLINE_WAITING_WORKER_SIGNAL",
    "wake_signals": [
      "WORKER_COMPLETION_RECEIPT",
      "WORKER_BLOCKER_RECEIPT",
      "WORKER_EXECUTION_FAILURE"
    ],
    "checker_periodic_worker_inspection": false
  },
  "worker_execution_gate": {
    "dispatcher": "paired Checker",
    "permission_provisioner": "Supervisor",
    "workspace_binding_required": true,
    "allowlist_preauthorized": true,
    "owner_routine_approval_forbidden": true,
    "unexpected_routine_approval_signal": "WORKER_EXECUTION_FAILURE",
    "owner_only_categories": [
      "credentials",
      "external_side_effects",
      "scope_or_acceptance_change",
      "destructive_or_security_sensitive_operation",
      "write_outside_allowlist"
    ]
  },
  "project_states": [
    "NOT_STARTED",
    "RUNNING",
    "PARTIALLY_PAUSED",
    "PAUSED",
    "BLOCKED",
    "COMPLETE"
  ],
  "pair_states": [
    "PLANNED",
    "RUNNING",
    "PAUSE_SCHEDULED",
    "PAUSE_PENDING",
    "PAUSED",
    "RESUME_SCHEDULED",
    "BLOCKED",
    "COMPLETE"
  ],
  "commands": [
    {
      "syntax": "MSLK START",
      "kind": "start",
      "scope": "all",
      "allowed_pair_states": ["PLANNED"],
      "to": "RUNNING",
      "manual_only": true,
      "dispatch": true,
      "requires": [
        "MSLK_READINESS_EVAL_PASS_EXACT_ROSTER",
        "AT_LEAST_TWO_INDEPENDENT_PAIRS",
        "ALL_FIRST_CELLS_READY",
        "ALL_PLANS_AND_DETECTION_PROFILES_APPROVED",
        "SIMULATION_PASS_EXACT_ROSTER",
        "CONTINUATION_CONDITIONS_PASS"
      ]
    },
    {
      "syntax": "MSLK STATUS ALL",
      "kind": "status",
      "scope": "all",
      "allowed_pair_states": ["PLANNED", "RUNNING", "PAUSE_SCHEDULED", "PAUSE_PENDING", "PAUSED", "RESUME_SCHEDULED", "BLOCKED", "COMPLETE"],
      "to": null,
      "read_only": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK STATUS PAIR <pair-id>",
      "kind": "status",
      "scope": "pair",
      "allowed_pair_states": ["PLANNED", "RUNNING", "PAUSE_SCHEDULED", "PAUSE_PENDING", "PAUSED", "RESUME_SCHEDULED", "BLOCKED", "COMPLETE"],
      "to": null,
      "read_only": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE ALL NOW",
      "kind": "pause",
      "scope": "all",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSED",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE PAIR <pair-id> NOW",
      "kind": "pause",
      "scope": "pair",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSED",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE ALL AFTER <accepted-cell-count>",
      "kind": "pause_schedule",
      "scope": "all",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSE_SCHEDULED",
      "threshold_scope": "project_accepted_absolute",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE PAIR <pair-id> AFTER <accepted-cell-count>",
      "kind": "pause_schedule",
      "scope": "pair",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSE_SCHEDULED",
      "threshold_scope": "pair_accepted_absolute",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE ALL AT <RFC3339-time>",
      "kind": "pause_schedule",
      "scope": "all",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSE_SCHEDULED",
      "time_format": "RFC3339",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK PAUSE PAIR <pair-id> AT <RFC3339-time>",
      "kind": "pause_schedule",
      "scope": "pair",
      "allowed_pair_states": ["RUNNING"],
      "to": "PAUSE_SCHEDULED",
      "time_format": "RFC3339",
      "safe_boundary": true,
      "dispatch": false
    },
    {
      "syntax": "MSLK RESUME ALL NOW",
      "kind": "resume",
      "scope": "all",
      "allowed_pair_states": ["PAUSED"],
      "to": "RUNNING",
      "same_pair": true,
      "revalidate": true,
      "dispatch": true
    },
    {
      "syntax": "MSLK RESUME PAIR <pair-id> NOW",
      "kind": "resume",
      "scope": "pair",
      "allowed_pair_states": ["PAUSED"],
      "to": "RUNNING",
      "same_pair": true,
      "revalidate": true,
      "dispatch": true
    },
    {
      "syntax": "MSLK RESUME ALL AT <RFC3339-time>",
      "kind": "resume_schedule",
      "scope": "all",
      "allowed_pair_states": ["PAUSED"],
      "to": "RESUME_SCHEDULED",
      "same_pair": true,
      "revalidate": true,
      "time_format": "RFC3339",
      "dispatch": false
    },
    {
      "syntax": "MSLK RESUME PAIR <pair-id> AT <RFC3339-time>",
      "kind": "resume_schedule",
      "scope": "pair",
      "allowed_pair_states": ["PAUSED"],
      "to": "RESUME_SCHEDULED",
      "same_pair": true,
      "revalidate": true,
      "time_format": "RFC3339",
      "dispatch": false
    },
    {
      "syntax": "MSLK CANCEL SCHEDULE ALL",
      "kind": "cancel_schedule",
      "scope": "all",
      "allowed_pair_states": ["PAUSE_SCHEDULED", "PAUSE_PENDING", "RESUME_SCHEDULED"],
      "to": "RUNNING",
      "to_by_state": {"PAUSE_SCHEDULED": "RUNNING", "PAUSE_PENDING": "RUNNING", "RESUME_SCHEDULED": "PAUSED"},
      "dispatch": false
    },
    {
      "syntax": "MSLK CANCEL SCHEDULE PAIR <pair-id>",
      "kind": "cancel_schedule",
      "scope": "pair",
      "allowed_pair_states": ["PAUSE_SCHEDULED", "PAUSE_PENDING", "RESUME_SCHEDULED"],
      "to": "RUNNING",
      "to_by_state": {"PAUSE_SCHEDULED": "RUNNING", "PAUSE_PENDING": "RUNNING", "RESUME_SCHEDULED": "PAUSED"},
      "dispatch": false
    }
  ],
  "project_state_derivation": [
    {"condition": "all_pairs_complete", "state": "COMPLETE"},
    {"condition": "all_incomplete_pairs_paused", "state": "PAUSED"},
    {"condition": "paused_and_dispatchable_incomplete_pairs_coexist", "state": "PARTIALLY_PAUSED"},
    {"condition": "no_incomplete_pair_dispatchable_and_any_pair_blocked", "state": "BLOCKED"},
    {"condition": "otherwise_after_start", "state": "RUNNING"}
  ],
  "all_scope_semantics": "best_effort_per_pair_with_partial_aggregate",
  "errors": {
    "INVALID_COMMAND": {"state_change": false, "dispatch": false, "roster_change": false},
    "INVALID_STATE": {"state_change": false, "dispatch": false, "roster_change": false},
    "PRECONDITION_FAILED": {"state_change": false, "dispatch": false, "roster_change": false},
    "UNKNOWN_PAIR": {"state_change": false, "dispatch": false, "roster_change": false},
    "SCHEDULE_CONFLICT": {"state_change": false, "dispatch": false, "roster_change": false},
    "ALREADY_APPLIED": {"state_change": false, "dispatch": false, "roster_change": false}
  },
  "receipt_fields": [
    "receipt_type",
    "command_id",
    "normalized_command",
    "actor",
    "target_scope",
    "pre_state",
    "trigger",
    "prerequisite_evidence",
    "action",
    "result",
    "post_state",
    "schedule_version",
    "per_target_results",
    "project_progress"
  ],
  "references": ["references/mslk-control-operations.md"]
}
